{
  "name": "YouTube NonStop",
  "short_name": "YT NonStop",
  "version": "0.9.3",
  "description": "Auto-skip YouTube's Continue Watching prompts.",
  "web_accessible_resources": [
    {
      "resources": [
        "autoconfirm.js"
      ],
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*",
        "https://music.youtube.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*",
        "https://music.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "images/yns16.png",
    "32": "images/yns32.png",
    "48": "images/yns48.png",
    "128": "images/yns128.png"
  },
  "manifest_version": 3
}